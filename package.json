{
  "name": "medical-app",
  "version": "1.0.10",
  "private": true,
  "scripts": {
    "android": "react-native run-android --variant=devDebug",
    "clear": "npx react-native start --reset-cache",
    "ios": "react-native run-ios --scheme medical-appDev --configuration DebugDev",
    "ios:x": "react-native run-ios --scheme medical-appDev --configuration DebugDev --simulator='iPhone X'",
    "ios:11": "react-native run-ios --scheme medical-appDev --configuration DebugDev --simulator='iPhone 11'",
    "ios:se": "react-native run-ios --scheme medical-appDev --configuration DebugDev --simulator='iPhone SE'",
    "ios:12promax": "react-native run-ios --scheme medical-appDev --configuration DebugDev --simulator='iPhone 12 Pro Max'",
    "ios:12pro": "react-native run-ios --scheme medical-appDev --configuration DebugDev --simulator='iPhone 12 Pro'",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "postversion": "react-native-version --never-amend"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^4.1.5",
    "@native-html/iframe-plugin": "^2.6.1",
    "@react-native-async-storage/async-storage": "^1.15.14",
    "@react-native-community/blur": "github:dromanchuck/react-native-blur",
    "@react-native-community/netinfo": "^8.1.0",
    "@react-navigation/drawer": "^6.1.8",
    "@react-navigation/elements": "^1.2.1",
    "@react-navigation/native": "^6.0.6",
    "@react-navigation/native-stack": "^6.2.5",
    "@sentry/react-native": "^3.3.2",
    "appcenter": "4.3.0",
    "appcenter-analytics": "4.3.0",
    "appcenter-crashes": "4.3.0",
    "axios": "^0.21.1",
    "domutils": "^2.8.0",
    "moment": "^2.29.1",
    "query-string": "^7.0.1",
    "react": "17.0.2",
    "react-native": "0.66.2",
    "react-native-bootsplash": "^4.0.2",
    "react-native-config": "^1.4.5",
    "react-native-gesture-handler": "^2.1.0",
    "react-native-linear-gradient": "^2.5.6",
    "react-native-mask-input": "^1.1.0",
    "react-native-paper": "^4.11.1",
    "react-native-reanimated": "^2.3.0",
    "react-native-render-html": "^6.3.1",
    "react-native-responsive-screen": "^1.4.2",
    "react-native-safe-area-context": "^3.3.2",
    "react-native-screens": "^3.10.1",
    "react-native-svg": "^12.1.1",
    "react-native-toast-message": "^2.1.1",
    "react-native-version": "^4.0.0",
    "react-native-webview": "^11.17.2",
    "react-query": "^3.34.16",
    "react-redux": "^7.2.6",
    "redux": "^4.1.2",
    "redux-saga": "^1.1.3",
    "reselect": "^4.1.5",
    "styled-components": "^5.3.3",
    "typesafe-actions": "^5.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.9",
    "@babel/runtime": "^7.12.5",
    "@react-native-community/eslint-config": "^2.0.0",
    "@types/jest": "^26.0.23",
    "@types/react-native": "^0.65.0",
    "@types/react-test-renderer": "^17.0.1",
    "@types/redux": "^3.6.0",
    "@types/styled-components": "^5.1.15",
    "@types/styled-components-react-native": "^5.1.3",
    "babel-jest": "^26.6.3",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-plugin-module-resolver": "^4.1.0",
    "eslint": "^7.14.0",
    "jest": "^26.6.3",
    "metro-react-native-babel-preset": "^0.66.2",
    "react-native-svg-transformer": "^0.14.3",
    "react-test-renderer": "17.0.2",
    "typescript": "^3.8.3"
  },
  "resolutions": {
    "@types/react": "^17"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  }
